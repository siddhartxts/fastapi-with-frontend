POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=fastapi
POSTGRES_PORT=5432

# Inside Docker Compose, the database host is the service name: db
SQLALCHEMY_DATABASE_URL=postgresql://postgres:change_me@db:5432/fastapi

# FastAPI app port on the host
API_PORT=8000

# Browser database viewer
ADMINER_PORT=8080
